[agent]
; Папка, куда сетевой сканер/МФУ кладёт сканы (локальная или примонтированная SMB).
; Windows-пример: watch_dir = \\\\NAS\\scans\\siri
watch_dir = /mnt/scans

; Эндпоинт приёма в CRM.
;   prod: https://siricrm.ru/scans/agent/intake/
;   dev:  https://crmsiri.ru/scans/agent/intake/
intake_url = https://siricrm.ru/scans/agent/intake/

; Тот же токен, что SCAN_AGENT_TOKEN в .env сервера.
token = ЗАМЕНИ_НА_ТОКЕН

; Метка устройства — видна секретарю в лотке (необязательно).
device = office-mfu-1

; Куда переносить успешно залитые файлы (чтобы не слать повторно).
; Пусто — оставлять на месте (агент помнит уже отправленные только до перезапуска).
done_dir = /mnt/scans/_uploaded

; Сколько дней хранить файлы в done_dir, потом удалять (раз в час).
; 0 — не чистить.
done_retention_days = 3

; Сколько секунд ждать стабилизации размера файла перед заливкой.
settle_seconds = 3

; Как часто опрашивать папку (сек). Агент опрашивает листинг каталога —
; это надёжно на сетевых (SMB) папках, где события файловой системы не приходят.
poll_interval = 5

; Проверять TLS-сертификат (false — только для самоподписанных, не для prod).
verify_tls = true
