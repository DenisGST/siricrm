# =========================================================================
# SiriCRM — production (.env.prod) для сервера 45.90.35.187 (siricrm.ru)
# Скопировать в .env.prod, заполнить РЕАЛЬНЫМИ значениями. В git НЕ коммитить.
# =========================================================================

# --- Django ---
DJANGO_ENV=prod
SECRET_KEY=__generate_50_chars__              # python -c "import secrets; print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=siricrm.ru,www.siricrm.ru
CSRF_TRUSTED_ORIGINS=https://siricrm.ru,https://www.siricrm.ru
CORS_ALLOWED_ORIGINS=https://siricrm.ru,https://www.siricrm.ru

# --- nginx (envsubst в default.conf.template) ---
NGINX_HOST=siricrm.ru
NGINX_HOST_WWW=www.siricrm.ru
LETSENCRYPT_EMAIL=admin@siricrm.ru

# --- Database ---
DATABASE_URL=postgresql://crm_user:CHANGE_ME@db:5432/crm_db
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- S3: prod media (старый бакет) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_BASE_URL=https://s3.ru1.storage.beget.cloud

# --- S3: бэкапы prod (отдельный бакет с отдельными ключами) ---
# Если ключи не заданы — fallback на AWS_* (бэкапы в media-бакет, префикс db-backups/)
AWS_BACKUP_BUCKET_NAME=
AWS_BACKUP_ACCESS_KEY_ID=
AWS_BACKUP_SECRET_ACCESS_KEY=
# AWS_BACKUP_S3_BASE_URL — если отличается от AWS_S3_BASE_URL
AWS_BACKUP_S3_BASE_URL=

# --- Telegram (production bot/userbot) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_STRING=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://siricrm.ru/telegram/webhook/
# Канал, куда лендинги шлют заявки (значение из @userinfobot, начинается с -100)
TELEGRAM_LEADS_CHANNEL_ID=
# Секретный сегмент пути webhook'а: openssl rand -hex 24
TELEGRAM_LEADS_WEBHOOK_SECRET=

# --- DaData ---
DADATA_API_KEY=
DADATA_SECRET_KEY=

# --- MAX bot ---
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=

# --- Arbitr (kad.arbitr.ru parser) ---
# MAX chat_id, куда слать алёрты при капче.
ARBITR_CAPTCHA_NOTIFY_MAX_CHAT_ID=

# --- Мониторинг доступности (ПРОД мониторит dev) ---
# Что проверять. Пусто → мониторинг выключен.
HEALTH_MONITOR_TARGET_URL=https://crmsiri.ru/health/
HEALTH_MONITOR_LABEL=DEV (crmsiri.ru)
# Куда слать алёрт о падении (на проде задать явно — chat арбитра тут пуст).
HEALTH_ALERT_MAX_CHAT_ID=
HEALTH_ALERT_TELEGRAM_CHAT_ID=
HEALTH_MONITOR_FAIL_THRESHOLD=2
# Telegram-бот мониторинга поллится на dev (MONITOR_BOT_POLL), на проде НЕ нужен.
MONITOR_BOT_POLL=false
# Headless Chromium для парсера. false — для отладки.
ARBITR_HEADLESS=true

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# --- DevOps Panel ---
# Токен, по которому dev-панель аутентифицируется в HTTP-агенте на проде.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEVOPS_AGENT_TOKEN=
# SCAN_AGENT_TOKEN — Bearer-токен локального scan-агента офиса (tools/scan-agent).
# Тот же токен прописывается в config.ini агента на офисном ПК.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCAN_AGENT_TOKEN=
# Путь к репозиторию на ХОСТЕ (нужен devops-runner для `docker compose build/up`)
HOST_REPO_DIR=/var/www/projects/siricrm
# Имя compose-файла, которым управляет этот сервер
COMPOSE_FILE_NAME=docker-compose.prod-host.yml

# --- WhatsApp (1msg.io) ---
WHATSAPP_INSTANCE_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE=
WHATSAPP_API_BASE=https://api.1msg.io
WHATSAPP_WEBHOOK_SECRET=
# На время пилота — true + allow-list своих номеров. После проверки → false.
WHATSAPP_TEST_MODE=true
WHATSAPP_ALLOWED_PHONES=

# --- Импорт из Bubble.io ---
BUBBLE_API_BASE=https://siricrmdev.ru/version-test/api/1.1/obj
BUBBLE_API_TOKEN=
