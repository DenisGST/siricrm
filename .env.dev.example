# =========================================================================
# SiriCRM — DEV (.env.dev) для сервера 5.35.94.218 (crmsiri.ru)
# Используется тот же docker-compose.prod.yml (HTTPS-стек), но dev-данные.
# Скопировать в .env.dev, заполнить значениями. В git НЕ коммитить.
# =========================================================================

# --- Django ---
# В dev можно оставить DJANGO_ENV=prod (тот же стек), но для удобства отладки
# можно также поставить DJANGO_ENV=dev — тогда DEBUG=True (НЕ рекомендуется на публичном HTTPS).
DJANGO_ENV=prod
SECRET_KEY=__generate_separate_dev_key__
ALLOWED_HOSTS=crmsiri.ru,www.crmsiri.ru
CSRF_TRUSTED_ORIGINS=https://crmsiri.ru,https://www.crmsiri.ru
CORS_ALLOWED_ORIGINS=https://crmsiri.ru,https://www.crmsiri.ru

# --- nginx ---
NGINX_HOST=crmsiri.ru
NGINX_HOST_WWW=www.crmsiri.ru
LETSENCRYPT_EMAIL=admin@crmsiri.ru

# --- Database (dev — пароль может отличаться от prod) ---
DATABASE_URL=postgresql://crm_user:CHANGE_ME_DEV@db:5432/crm_db
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_DEV

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- S3: dev media (новый бакет 1464bbae4a12-siridev-s3) ---
AWS_ACCESS_KEY_ID=JCZD7I51FRR44FWUS6LW
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=1464bbae4a12-siridev-s3
AWS_S3_REGION_NAME=us-east-1
AWS_S3_BASE_URL=https://s3.ru1.storage.beget.cloud

# --- S3: бэкапы dev (тот же бакет, в подпапку db-backups/) ---
# dev: бэкапы в тот же бакет с теми же ключами (AWS_BACKUP_* не нужны)
AWS_BACKUP_BUCKET_NAME=1464bbae4a12-siridev-s3

# --- Telegram: ОТДЕЛЬНЫЙ тестовый бот для dev ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_STRING=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://crmsiri.ru/telegram/webhook/

# --- DaData ---
DADATA_API_KEY=
DADATA_SECRET_KEY=

# --- MAX bot ---
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=

# --- Sentry (можно отдельный проект для dev или общий) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- DevOps Panel ---
# DEVOPS_AGENT_TOKEN — токен ЭТОГО dev-агента (если когда-нибудь будем управлять с prod, не нужен сейчас)
DEVOPS_AGENT_TOKEN=
# DEVOPS_AGENT_TOKEN_PROD — тот же токен что в .env.prod на 45.90.35.187. Dev-панель шлёт его в Bearer.
DEVOPS_AGENT_TOKEN_PROD=
# Путь к репозиторию на ХОСТЕ (нужен devops-runner для `docker compose build/up`)
HOST_REPO_DIR=/var/www/siricrm
COMPOSE_FILE_NAME=docker-compose.prod.yml
